# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── AI Provider ──────────────────────────────────────────────
# "groq"   → free API, cloud deployment (recommended for production)
# "ollama" → free, runs locally (recommended for development)
# "openai" → paid, best quality
AI_PROVIDER=ollama
AI_MODEL=qwen2.5-coder:1.5b
OLLAMA_BASE_URL=http://localhost:11434/v1
# GROQ_API_KEY=gsk_...     (get free key at console.groq.com)
# OPENAI_API_KEY=sk-...    (only needed if AI_PROVIDER=openai)

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Email ─────────────────────────────────────────────────────
# Leave SMTP_USER blank to use Ethereal auto-account (development)
# For Gmail: set SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
#            use an App Password (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Fortress <noreply@yourcompany.com>
ADMIN_EMAIL=

# ── Salesforce (add when account is ready) ───────────────────
# SF_LOGIN_URL=https://login.salesforce.com
# SF_CLIENT_ID=3MVG9...
# SF_CLIENT_SECRET=ABC123...
# SF_USERNAME=your.user@org.com
# SF_PASSWORD=yourpassword
# SF_SECURITY_TOKEN=yourSecurityToken
